{
  "schemaVersion": 6,
  "owner": "Meta_Kim",
  "businessWorkflow": {
    "id": "business",
    "distinctFromCanonicalSpine": true,
    "canonicalExecutionSpineRef": "meta-theory Type C: Critical → Fetch → Thinking → Execution → Review → Meta-Review → Verification → Evolution (see canonical/skills/meta-theory/references/dev-governance.md). Business phase ids here are department-run vocabulary only; they do not rename or substitute spine stage names.",
    "canonicalExecutionSpineStages": [
      "critical",
      "fetch",
      "thinking",
      "execution",
      "review",
      "meta_review",
      "verification",
      "evolution"
    ],
    "phases": [
      "direction",
      "planning",
      "execution",
      "review",
      "meta_review",
      "revision",
      "verify",
      "summary",
      "feedback",
      "evolve"
    ],
    "markerPhases": [
      "meta_review",
      "verify",
      "evolve"
    ],
    "terminalPhases": [
      "review",
      "meta_review",
      "verify",
      "summary",
      "feedback",
      "evolve"
    ],
    "summaryPreference": [
      "summary",
      "verify",
      "revision",
      "execution",
      "planning",
      "direction"
    ],
    "labels": {
      "zh-CN": {
        "direction": "CEO方向",
        "planning": "经理规划",
        "execution": "执行产出",
        "review": "经理评审",
        "meta_review": "元部门审计",
        "revision": "修改迭代",
        "verify": "经理验证",
        "summary": "经理汇总",
        "feedback": "CEO反馈",
        "evolve": "Agent进化"
      },
      "en-US": {
        "direction": "CEO Direction",
        "planning": "Manager Planning",
        "execution": "Execution",
        "review": "Manager Review",
        "meta_review": "Meta Audit",
        "revision": "Revision",
        "verify": "Manager Verify",
        "summary": "Manager Summary",
        "feedback": "CEO Feedback",
        "evolve": "Agent Evolution"
      }
    }
  },
  "metaWorkflow": {
    "id": "meta",
    "phases": [
      "analyze",
      "propose",
      "report"
    ],
    "labels": {
      "zh-CN": {
        "analyze": "元分析",
        "propose": "元提案",
        "report": "元报告"
      },
      "en-US": {
        "analyze": "Meta Analysis",
        "propose": "Meta Proposal",
        "report": "Meta Report"
      }
    }
  },
  "gates": {
    "planning": {
      "owner": "meta-conductor",
      "passToken": "Pass",
      "reworkToken": "Requires Re-scheduling"
    },
    "metaReview": {
      "owners": [
        "meta-warden",
        "meta-prism"
      ]
    },
    "verify": {
      "owners": [
        "meta-warden",
        "meta-prism"
      ]
    },
    "summary": {
      "owner": "meta-warden",
      "requiresVerifiedRun": true
    },
    "dealer": {
      "primaryOwner": "meta-conductor",
      "escalationOwner": "meta-warden",
      "interruptSources": [
        "meta-sentinel",
        "meta-prism",
        "user",
        "system"
      ]
    },
    "publicDisplay": {
      "owner": "meta-warden",
      "hardReleaseGate": true,
      "blockFinalDraftWithoutVerifiedRun": true,
      "blockExternalDisplayWithoutSummaryClosure": true,
      "blockCompletionWithoutClosedDeliverableChain": true,
      "requiredConditions": [
        "verifyPassed",
        "summaryClosed",
        "singleDeliverableMaintained",
        "deliverableChainClosed",
        "consolidatedDeliverablePresent"
      ]
    }
  },
  "runDiscipline": {
    "singleDepartmentPerRun": true,
    "singlePrimaryDeliverable": true,
    "rejectMultiTopicRuns": true,
    "rejectDetachedWorkerTasks": true,
    "requireClosedDeliverableChain": true,
    "queryBypassRule": {
      "onlyPureQueryMayBypassAgentOwner": true,
      "pureQueryCriteria": [
        "no_file_or_code_change",
        "no_external_side_effect",
        "no_durable_execution_artifact",
        "no_downstream_handoff_required"
      ]
    },
    "taskClassification": {
      "classifierVersion": "v2",
      "taskClassEnum": [
        "Q",
        "A",
        "P",
        "S"
      ],
      "requestClassEnum": [
        "query",
        "execute",
        "plan",
        "strategy"
      ],
      "queryScopeEnum": [
        "current_project",
        "all_projects"
      ],
      "registryStatusEnum": [
        "known",
        "prompt_join",
        "joined",
        "skipped"
      ],
      "governanceFlowEnum": [
        "query",
        "simple_exec",
        "complex_dev",
        "meta_analysis",
        "proposal_review",
        "rhythm"
      ],
      "triggerReasonEnum": [
        "multi_file",
        "cross_module",
        "external_side_effect",
        "durable_artifact",
        "owner_missing",
        "cross_runtime_sync",
        "security_sensitive",
        "verification_required",
        "writeback_candidate",
        "user_explicit_review"
      ],
      "upgradeReasonEnum": [
        "cross_system_scope",
        "review_or_verify_required",
        "owner_creation_required",
        "parallel_merge_required",
        "business_workflow_upgrade",
        "security_gate_required"
      ],
      "bypassReasonEnum": [
        "pure_query",
        "read_only_explanation",
        "existing_verified_artifact_reuse"
      ],
      "ownerRequiredByDefault": true,
      "onlyQueryMayBypassOwner": true
    },
    "cardGovernance": {
      "enabled": true,
      "dealerRoleModel": "conductor-primary-warden-escalation",
      "cardTypeEnum": [
        "info",
        "action",
        "risk",
        "silence",
        "default",
        "upgrade"
      ],
      "cardIntentEnum": [
        "clarify",
        "scope_contract",
        "plan",
        "execute",
        "review",
        "verify",
        "repair",
        "rollback",
        "risk_surface",
        "suggest",
        "silence",
        "default_path",
        "escalate"
      ],
      "cardDecisionEnum": [
        "deal",
        "suppress",
        "defer",
        "skip",
        "interrupt_insert",
        "escalate"
      ],
      "cardAudienceEnum": [
        "user",
        "owner",
        "reviewer",
        "governance",
        "runtime"
      ],
      "cardTimingEnum": [
        "immediate",
        "next_stage",
        "after_dependency",
        "after_verify",
        "on_risk",
        "on_timeout",
        "on_user_request"
      ],
      "cardTimingDescriptions": {
        "immediate": "立即执行，不等待任何前置条件",
        "next_stage": "等待下一个阶段开始后执行",
        "after_dependency": "等待dependsOn中声明的所有依赖项满足后执行（channel/gate/event三种语义，见dependencyContract）",
        "after_verify": "等待验证阶段完成后执行",
        "on_risk": "风险信号触发时执行",
        "on_timeout": "超时事件触发时执行",
        "on_user_request": "用户明确请求时执行"
      },
      "cardShellEnum": [
        "conversation",
        "file",
        "packet",
        "agent_dispatch",
        "summary",
        "silent_hold"
      ],
      "cardSourceEnum": [
        "meta-conductor",
        "meta-warden",
        "meta-sentinel",
        "meta-prism",
        "system",
        "user"
      ],
      "suppressionReasonEnum": [
        "attention_budget_low",
        "already_known",
        "already_in_context",
        "verification_pending",
        "public_display_blocked",
        "no_clear_intervention_gain"
      ],
      "defaultNoCardPolicy": "prefer_silence_without_clear_intervention_gain"
    },
    "silencePolicy": {
      "noInterventionPreferred": true,
      "silenceDecisionEnum": [
        "none",
        "no_card",
        "defer",
        "intentional_silence"
      ],
      "defaultWhen": [
        "no_clear_intervention_gain",
        "user_already_has_context",
        "attention_budget_exceeded",
        "public_display_blocked_pending_verification"
      ],
      "requiresInterruptionJustification": true,
      "deferRequiresDeadline": true
    },
    "controlIntervention": {
      "decisionTypeEnum": [
        "skip",
        "interrupt",
        "override",
        "escalation_insert"
      ],
      "skipReasonEnum": [
        "already_known",
        "already_in_context",
        "attention_budget_low",
        "not_applicable",
        "artifact_not_needed"
      ],
      "interruptReasonEnum": [
        "security_risk",
        "quality_drift",
        "user_urgent",
        "system_failure",
        "global_impact"
      ],
      "overrideReasonEnum": [
        "security_override",
        "verification_block",
        "public_display_block",
        "governance_owner_insert"
      ],
      "insertedGovernanceOwners": [
        "meta-sentinel",
        "meta-prism",
        "meta-warden",
        "meta-conductor"
      ],
      "requiresReturnToMainChain": true
    },
    "deliveryShell": {
      "shellTypeEnum": [
        "one_line",
        "structured_status",
        "technical_detail",
        "review_delta",
        "executive_summary",
        "artifact_link"
      ],
      "presentationModeEnum": [
        "direct",
        "digest",
        "deferred",
        "quiet"
      ],
      "exposureLevelEnum": [
        "internal",
        "review",
        "public"
      ],
      "interventionFormEnum": [
        "conversation",
        "file_write",
        "task_packet",
        "agent_dispatch",
        "notification",
        "none"
      ]
    },
    "executionOwnership": {
      "executionRequiresAgentOwner": true,
      "anonymousExecutionForbidden": true,
      "existingOwnerPreferred": true,
      "createOwnerBeforeExecutionWhen": [
        "recurring_capability_gap",
        "project_specific_domain_gap",
        "workflow_blocked_by_missing_declared_owner"
      ],
      "temporaryFallback": {
        "allowed": true,
        "subagentType": "generalPurpose",
        "emergencyOnly": true,
        "oneOffPreferred": true,
        "requiresExplicitOwnerLabel": true,
        "requiresJustification": true,
        "requiresEvolutionReview": true
      }
    },
    "parallelism": {
      "mustParallelizeIndependentTasks": true,
      "requiresDependencyDeclaration": true,
      "requiresParallelGroup": true,
      "requiresMergeOwner": true
    },
    "protocolFirst": {
      "enabled": true,
      "requiredPackets": [
        "runHeader",
        "taskClassification",
        "fetchPacket",
        "cardPlanPacket",
        "dispatchEnvelopePacket",
        "orchestrationTaskBoardPacket",
        "dispatchBoard",
        "workerTaskPacket",
        "workerResultPacket",
        "reviewPacket",
        "verificationPacket",
        "summaryPacket",
        "evolutionWritebackPacket"
      ],
      "dispatchEnvelopePacketRequiredWhenGovernanceFlows": [
        "simple_exec",
        "complex_dev",
        "meta_analysis",
        "proposal_review",
        "rhythm"
      ],
      "orchestrationTaskBoardPacketRequiredWhenGovernanceFlows": [
        "simple_exec",
        "complex_dev",
        "meta_analysis",
        "proposal_review",
        "rhythm"
      ],
      "capabilityGapPacketRequiredWhenUpgradeReasons": [
        "owner_creation_required"
      ],
      "executionAgentCardRequiredWhenResolutionActions": [
        "create_execution_agent",
        "upgrade_execution_agent"
      ],
      "intentPacketRequiredWhenGovernanceFlows": [
        "complex_dev",
        "meta_analysis"
      ],
      "intentGatePacketRequiredWhenGovernanceFlows": [
        "complex_dev",
        "meta_analysis"
      ],
      "description": "intentPacket is required in run artifacts when taskClassification.governanceFlow is listed in intentPacketRequiredWhenGovernanceFlows (IntentGate-style intent lock-in). intentGatePacket is required for the same flows (structured ambiguity / assumptions gate before Execution). dispatchEnvelopePacket is required for all non-pure-query flows so every executable run has an explicit owner, capability boundary, memory mode, and review / verification routing before dispatch. orchestrationTaskBoardPacket is the mandatory Conductor task board for the same executable flows. capabilityGapPacket is required when taskClassification.upgradeReasons records owner_creation_required. executionAgentCard is required when capabilityGapPacket resolves the gap through execution-agent creation or upgrade."
    },
    "localState": {
      "root": ".meta-kim/state",
      "defaultProfile": "default",
      "profileKeyRequires": [
        "repo_path_hash",
        "runtime_family"
      ],
      "trackedFilesForbidden": true,
      "runIndex": {
        "pathPattern": ".meta-kim/state/{profile}/run-index.sqlite",
        "indexesValidatedArtifactsOnly": true,
        "canonicalSource": false
      },
      "globalProjectRegistry": {
        "pathPattern": "~/.meta-kim/global/project-registry.sqlite",
        "storesProjectBodies": false,
        "storesProjectRegistryOnly": true
      },
      "compaction": {
        "pathPattern": ".meta-kim/state/{profile}/compaction/",
        "localOnly": true,
        "publicArtifactForbidden": true
      },
      "doctorCache": {
        "pathPattern": ".meta-kim/state/{profile}/doctor-cache/",
        "localOnly": true
      }
    },
    "findingClosure": {
      "findingIdRequired": true,
      "reviewFindingRequiresRevisionResponse": true,
      "revisionResponseRequiresFixArtifact": true,
      "verificationRequiresFreshEvidence": true,
      "closureRequiresVerificationResult": true,
      "closeStateEnum": [
        "open",
        "fixed_pending_verify",
        "verified_closed",
        "accepted_risk"
      ],
      "legalTransitions": [
        "open->fixed_pending_verify",
        "fixed_pending_verify->verified_closed",
        "fixed_pending_verify->accepted_risk"
      ]
    },
    "reviewMustConsolidate": true,
    "reviewOutputProtocol": {
      "format": "deliverable-frontmatter",
      "marker": "<!--deliverable",
      "endMarker": "-->",
      "requiredFields": ["title", "summary", "workers"],
      "workersFields": ["name", "task"],
      "separator": "---",
      "sections": ["frontmatter", "consolidatedBody", "separator", "perWorkerScores"],
      "description": "Review phase output must start with a deliverable frontmatter block containing title, summary, and worker roles in YAML. After the frontmatter, the consolidated deliverable body follows. A --- separator divides the body from per-worker scores."
    },
    "requiredRunHeader": [
      "department",
      "primaryDeliverable",
      "audience",
      "freshnessRequirement",
      "visualPolicy",
      "handoffPlan"
    ],
    "requiredWorkerFields": [
      "todayTask",
      "output",
      "deliverableLink",
      "qualityBar",
      "referenceDirection",
      "handoffTarget",
      "lengthExpectation",
      "visualOrAssetPlan",
      "owner",
      "ownerMode",
      "dependsOn",
      "parallelGroup",
      "mergeOwner",
      "taskPacketId"
    ],
    "evolutionWritebackRequired": true,
    "evolutionDecision": {
      "required": true,
      "allowedDecisions": [
        "writeback",
        "none"
      ],
      "noneRequiresReason": true,
      "writebackRequiresTargets": true
    },
"evolutionWritebackTargets": [
      "canonical/agents/{agent}.md",
      "canonical/skills/"
    ],
    "publicDisplayRequires": [
      "verifyPassed",
      "summaryClosed",
      "singleDeliverableMaintained",
      "deliverableChainClosed",
      "consolidatedDeliverablePresent"
    ],
    "publicDisplayGate": {
      "hardReleaseGate": true,
      "blockDisplayBeforeVerification": true,
      "blockDisplayBeforeSummaryClosure": true,
      "blockCompletionBeforeDeliverableClosure": true
    },
    "runArtifactValidation": {
      "script": "scripts/validate-run-artifact.mjs",
      "findingLineageRequired": true,
      "deliverableLinkMustReferencePrimaryDeliverable": true,
      "publicReadyField": "summaryPacket.publicReady",
      "summaryPacketRequired": true,
      "cardPlanPacketRequired": true,
      "orchestrationTaskBoardPacketRequired": true,
      "dispatchEnvelopePacketRequiredForNonQuery": true,
      "compactionPacketOptional": true,
      "compactionPacketLocalOnly": true,
      "compactionPacketMustPreserveOpenFindings": true,
      "compactionPacketPublicReadyRequiresVerifiedRun": true,
      "softPublicReadyTodoGate": {
        "environmentVariable": "META_KIM_SOFT_PUBLIC_READY_GATES",
        "environmentValue": "1",
        "optionalWorkerField": "taskTodoState",
        "description": "When the env var is set to 1 and summaryPacket.publicReady is true, no workerTaskPacket may have taskTodoState === \"open\". Omitted field is treated as compliant."
      },
      "softCommentReviewGate": {
        "environmentVariable": "META_KIM_SOFT_COMMENT_REVIEW",
        "environmentValue": "1",
        "summaryBooleanField": "commentReviewAcknowledged",
        "description": "When the env var is set to 1 and summaryPacket.publicReady is true, summaryPacket.commentReviewAcknowledged must be true (team acknowledgment that comments/docs were reviewed for AI-slop patterns)."
      }
    }
  },
  "protocols": {
    "runHeader": {
      "requiredFields": [
        "department",
        "primaryDeliverable",
        "audience",
        "freshnessRequirement",
        "visualPolicy",
        "handoffPlan"
      ]
    },
    "taskClassification": {
      "requiredFields": [
        "taskClass",
        "requestClass",
        "queryScope",
        "projectRef",
        "registryStatus",
        "crossProjectReason",
        "governanceFlow",
        "triggerReasons",
        "upgradeReasons",
        "bypassReasons",
        "ownerRequired",
        "decisionSource",
        "classifierVersion",
        "complexity"
      ]
    },
    "fetchPacket": {
      "requiredFields": [
        "projectsChecked",
        "projectLocalSources",
        "globalRegistryHits",
        "capabilityMatches",
        "capabilityGaps",
        "graphSources",
        "knowledgeSources"
      ],
      "description": "Explicit Fetch-stage packet: which projects were checked, which local/global sources were consulted, which capabilities matched, which gaps remain, and which graph/knowledge sources influenced the run."
    },
    "intentPacket": {
      "requiredFields": [
        "trueUserIntent",
        "successCriteria",
        "nonGoals",
        "intentPacketVersion"
      ],
      "description": "Structured user-intent lock before heavy execution: what they really want, how we know we are done, and explicit out-of-scope items."
    },
    "intentGatePacket": {
      "requiredFields": [
        "ambiguitiesResolved",
        "requiresUserChoice",
        "defaultAssumptions",
        "intentGatePacketVersion"
      ],
      "description": "Structured pre-execution gate: whether ambiguities are cleared, if the user must still choose, documented default assumptions, aligned with intentPacket fields."
    },
    "cardPlanPacket": {
      "requiredFields": [
        "dealerOwner",
        "dealerMode",
        "cards",
        "deliveryShells",
        "silenceDecision",
        "controlDecisions",
        "defaultShellId"
      ]
    },
    "dispatchEnvelopePacket": {
      "requiredFields": [
        "ownerAgent",
        "taskRef",
        "allowedCapabilities",
        "blockedCapabilities",
        "route",
        "ownerSelection",
        "memoryMode",
        "workspaceHint",
        "resultSchemaRef",
        "reviewOwner",
        "verificationOwner"
      ],
      "routeEnum": [
        "project_only",
        "cross_project"
      ],
      "ownerSelectionEnum": [
        "capability_first"
      ],
      "memoryModeEnum": [
        "project_only",
        "cross_project_readonly"
      ],
      "description": "Mandatory execution shell for non-query flows: who owns the task, which capabilities are allowed/blocked, what memory policy the child gets, and which owners close review / verification."
    },
    "orchestrationTaskBoardPacket": {
      "requiredFields": [
        "dispatchBoardId",
        "boardMode",
        "tasks",
        "synthesisOwner"
      ],
      "boardModeEnum": [
        "direct_dispatch",
        "factory_then_dispatch"
      ],
      "description": "Conductor-owned task board for executable work. It says who does what, in what order, what each task must deliver, and who synthesizes the final result."
    },
    "orchestrationTask": {
      "requiredFields": [
        "taskId",
        "taskKind",
        "owner",
        "sequence",
        "dependsOn",
        "deliverable"
      ],
      "taskKindEnum": [
        "execution",
        "factory_build",
        "factory_upgrade"
      ],
      "description": "Conductor编排板中的单个任务单元。dependsOn声明前置依赖，见dependencyContract定义。"
    },
    "capabilityGapPacket": {
      "requiredFields": [
        "gapId",
        "requestedCapability",
        "currentAgentsChecked",
        "insufficiencyReason",
        "resolutionAction",
        "requestedBy",
        "approvedBy"
      ],
      "resolutionActionEnum": [
        "create_execution_agent",
        "upgrade_execution_agent",
        "reuse_existing_owner",
        "accepted_gap"
      ],
      "description": "Human-language capability gap sheet. It records why current owners are insufficient and what decision was made before the execution-agent factory starts."
    },
    "executionAgentCard": {
      "requiredFields": [
        "agentId",
        "purpose",
        "capabilities",
        "nonCapabilities",
        "dependencies",
        "inputs",
        "outputs"
      ],
      "description": "Mandatory execution-agent role card whenever the factory creates or upgrades an execution agent. The card defines purpose, boundaries, dependencies, inputs, and outputs."
    },
    "cardDecision": {
      "requiredFields": [
        "cardId",
        "cardType",
        "cardIntent",
        "cardDecision",
        "cardAudience",
        "cardTiming",
        "cardShell",
        "cardPriority",
        "cardReason",
        "cardSource",
        "cardSuppressed",
        "suppressionReason",
        "deliveryShellId"
      ]
    },
    "deliveryShell": {
      "requiredFields": [
        "deliveryShellId",
        "shellType",
        "presentationMode",
        "exposureLevel",
        "interventionForm",
        "audience",
        "contentBoundary"
      ]
    },
    "silenceDecision": {
      "requiredFields": [
        "silenceDecision",
        "noInterventionPreferred",
        "interruptionJustified",
        "deferUntil",
        "reasonForSilence"
      ]
    },
    "controlDecision": {
      "requiredFields": [
        "decisionId",
        "decisionType",
        "skipReason",
        "interruptReason",
        "overrideReason",
        "insertedGovernanceOwner",
        "emergencyGovernanceTriggered",
        "returnsToStage",
        "rejoinCondition"
      ]
    },
    "dispatchBoard": {
      "requiredFields": [
        "boardId",
        "goal",
        "ownerResolution",
        "primaryDeliverable",
        "mergeStrategy"
      ]
    },
    "workerTaskPacket": {
      "requiredFields": [
        "taskPacketId",
        "owner",
        "ownerMode",
        "todayTask",
        "output",
        "deliverableLink",
        "qualityBar",
        "referenceDirection",
        "handoffTarget",
        "lengthExpectation",
        "visualOrAssetPlan",
        "dependsOn",
        "parallelGroup",
        "mergeOwner"
      ],
      "description": "派发给worker agent的执行任务包。三大编排核心字段：dependsOn（前置依赖，见dependencyContract）/ parallelGroup（并行分组）/ mergeOwner（合并负责人）。",
      "dependsOnField": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["taskRef"],
          "properties": {
            "taskRef": {
              "type": "string",
              "description": "依赖的任务ID（对应源workerTaskPacket.taskPacketId）"
            },
            "type": {
              "type": "string",
              "enum": ["channel", "gate", "event"],
              "description": "channel=点对点消息传递/gate=质量门放行/event=发布订阅"
            },
            "timeout_ms": {
              "type": "integer",
              "default": 300000,
              "description": "等待依赖满足的超时时间（毫秒），默认5分钟"
            },
            "retry": {
              "type": "object",
              "description": "超时后重试策略",
              "properties": {
                "max": { "type": "integer", "default": 3, "description": "最大重试次数" },
                "backoff_ms": { "type": "integer", "default": 5000, "description": "重试间隔（毫秒），支持指数退避" }
              }
            },
            "onTimeout": {
              "type": "string",
              "enum": ["skip", "abort", "use_fallback"],
              "description": "超时行为：skip=跳过依赖继续/abort=中止任务/use_fallback=使用兜底产物"
            },
            "fallback": {
              "type": "object",
              "description": "use_fallback时的兜底配置",
              "properties": {
                "artifact": { "type": "string", "description": "兜底产物路径或默认schema路径" }
              }
            }
          }
        }
      },
