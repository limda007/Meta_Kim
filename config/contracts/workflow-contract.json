    "dependencyContract": {
      "description": "编排顺序依赖契约——定义agent间前后关系的标准格式。三种依赖语义覆盖所有前后端联调场景。",
      "threeModes": {
        "channel": {
          "label": "通道式（点对点消息）",
          "semantic": "producer生成消息，consumer从共享存储（artifact store）读取locator。消息体不经过dispatcher信道，避免payload膨胀。",
          "useCase": "前后端artifact传递、文件产物交接、API响应回传",
          "example": "frontend_agent产出build产物路径 → backend_agent读取build hash继续编译"
        },
        "gate": {
          "label": "阶段门式（质量门）",
          "semantic": "前置任务产出物必须通过schema验证才放行后续任务。不是简单的时间等待，是质量关卡。",
          "useCase": "OpenAPI schema校验、代码规范检查、安全扫描通过后才推进",
          "example": "frontend_agent输出api-contract.yaml → backend_agent必须验证schema含paths/components才生成代码"
        },
        "event": {
          "label": "事件订阅式",
          "semantic": "producer发布事件，consumer订阅并可选filter过滤。blocking=true则等待，false则旁听。",
          "useCase": "部署完成事件、CI通过事件、监控告警事件触发后续任务",
          "example": "deploy_agent发布deployment_started事件 → smoke_test_agent订阅并filter=env==staging才执行"
        }
      },
      "timeoutStrategy": {
        "default": 300000,
        "unit": "milliseconds",
        "retryBackoff": "exponential",
        "maxRetries": 3,
        "recommendation": "前端构建类依赖建议600000ms（10分钟），接口响应类建议300000ms（5分钟），CI任务建议60000ms（1分钟）"
      },
      "dagValidation": "dependsOn声明在Stage 3（Thinking）由Conductor构建DAG图。必须检测循环依赖，循环依赖的task不得进入Stage 4。",
      "frontendBackendContract": {
        "description": "前后端联调的标准依赖模板",
        "frontendEmits": {
          "type": "gate",
          "outputSchema": "openapi_schema",
          "requiredFields": ["openapi", "info", "paths"],
          "minPaths": 3,
          "qualityGate": true
        },
        "backendDepends": {
          "type": "gate",
          "from": "frontend_agent",
          "timeout_ms": 600000,
          "retry": { "max": 2, "backoff_ms": 30000 },
          "onTimeout": "use_fallback",
          "fallback": { "artifact": "schemas/fallback-api.yaml" }
        }
      }
    }
  },
